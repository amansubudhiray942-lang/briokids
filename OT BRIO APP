        <div style={{overflowX:"auto",display:"flex",gap:5,paddingBottom:5}}>
          {["All",...CONDITIONS].map(c=><button key={c} onClick={()=>setFCond(c)} style={{whiteSpace:"nowrap",padding:"5px 11px",borderRadius:20,border:`2px solid ${fCond===c?C.primary:"#e5e7eb"}`,background:fCond===c?C.light:"#fff",color:fCond===c?C.primary:"#6b7280",fontWeight:600,cursor:"pointer",fontSize:10}}>{c}</button>)}
        </div>
        <div style={{overflowX:"auto",display:"flex",gap:5,paddingBottom:5}}>
          {["All","Sensory","Fine Motor","Gross Motor","Cognitive","Social"].map(g=><button key={g} onClick={()=>setFGoal(g)} style={{whiteSpace:"nowrap",padding:"5px 10px",borderRadius:20,border:`2px solid ${fGoal===g?C.accent:"#e5e7eb"}`,background:fGoal===g?"#d1fae5":"#fff",color:fGoal===g?C.accent:"#6b7280",fontWeight:600,cursor:"pointer",fontSize:10}}>{g}</button>)}
        </div>
        <div style={{overflowX:"auto",display:"flex",gap:5,paddingBottom:5}}>
          {AGE_GROUPS.map(a=><button key={a} onClick={()=>setFAge(a)} style={{whiteSpace:"nowrap",padding:"5px 10px",borderRadius:20,border:`2px solid ${fAge===a?"#f59e0b":"#e5e7eb"}`,background:fAge===a?"#fef3c7":"#fff",color:fAge===a?"#d97706":"#6b7280",fontWeight:600,cursor:"pointer",fontSize:10}}>{a}</button>)}
        </div>
        <div style={{fontSize:11,color:"#6b7280",marginBottom:5}}>{filtered.length} activit{filtered.length===1?"y":"ies"} found</div>
      </div>
      <div style={{flex:1,overflowY:"auto",padding:"0 13px 13px"}}>
        {filtered.map(a=>(
          <div key={a.id} onClick={()=>setSelAct(a)} style={{background:"#fff",borderRadius:13,padding:13,marginBottom:9,cursor:"pointer",boxShadow:"0 2px 8px rgba(0,0,0,0.07)"}}>
            <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start"}}>
              <div style={{flex:1,marginRight:7}}>
                <div style={{fontWeight:700,fontSize:13,color:"#1f2937"}}>{a.title}</div>
                <div style={{fontSize:10,color:"#6b7280",margin:"2px 0"}}>{a.desc}</div>
                <div style={{display:"flex",gap:4,flexWrap:"wrap",marginTop:6}}>
                  <span style={{background:C.light,color:C.primary,borderRadius:7,padding:"2px 6px",fontSize:9,fontWeight:600}}>{a.goal}</span>
                  <LBadge level={a.level}/>
                  <span style={{background:"#f0fdf4",color:"#166534",borderRadius:7,padding:"2px 6px",fontSize:9,fontWeight:600}}>👶 {a.age}</span>
                </div>
              </div>
              <span style={{fontSize:18}}>▶️</span>
            </div>
          </div>
        ))}
      </div>
      {selAct&&(
        <div style={{position:"fixed",inset:0,background:"rgba(0,0,0,0.6)",display:"flex",alignItems:"flex-end",zIndex:100}}>
          <div style={{background:"#fff",borderRadius:"18px 18px 0 0",padding:17,width:"100%",maxHeight:"88vh",overflowY:"auto",boxSizing:"border-box"}}>
            <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:11}}>
              <div style={{fontWeight:700,fontSize:16,color:"#1f2937",flex:1,marginRight:8}}>{selAct.title}</div>
              <button onClick={()=>setSelAct(null)} style={{background:"#f3f4f6",border:"none",borderRadius:8,padding:"4px 10px",cursor:"pointer",fontSize:15}}>✕</button>
            </div>
            <VThumb a={selAct}/>
            <div style={{fontSize:13,color:"#374151",marginBottom:7}}>{selAct.desc}</div>
            <div style={{fontSize:11,color:"#6b7280",marginBottom:9}}>🎒 Materials: {selAct.mat}</div>
            <div style={{display:"flex",gap:6,flexWrap:"wrap",marginBottom:13}}>
              <span style={{background:C.light,color:C.primary,borderRadius:7,padding:"3px 9px",fontSize:11,fontWeight:600}}>{selAct.goal}</span>
              <LBadge level={selAct.level}/>
              <span style={{background:"#f0fdf4",color:"#166534",borderRadius:7,padding:"3px 9px",fontSize:11,fontWeight:600}}>👶 {selAct.age}</span>
            </div>
            <button onClick={()=>{setLogAct(selAct);setSelAct(null);setScreen("log");}} style={{width:"100%",background:C.primary,color:"#fff",border:"none",borderRadius:12,padding:12,fontSize:13,fontWeight:700,cursor:"pointer"}}>📋 Log This Activity</button>
          </div>
        </div>
      )}
      <NavBar/>
    </div>
  );

  if(screen==="log")return(
    <div style={{fontFamily:"sans-serif",background:C.bg,height:"100vh",display:"flex",flexDirection:"column",overflow:"hidden"}}>
      <Header title="📝 Log Activity"/>
      <div style={{flex:1,overflowY:"auto",padding:14}}>
        <div style={{background:"#fff",borderRadius:16,padding:17,boxShadow:"0 2px 8px rgba(0,0,0,0.08)"}}>
          {logAct&&<div style={{background:C.light,borderRadius:11,padding:11,marginBottom:13,fontWeight:600,color:C.primary,fontSize:13}}>🧩 {logAct.title}</div>}
          <div style={{marginBottom:13}}>
            <div style={{fontSize:12,fontWeight:600,color:"#374151",marginBottom:7}}>How did it go? *</div>
            <div style={{display:"flex",gap:7}}>
              {MOODS.map(m=><button key={m} onClick={()=>setLogForm(p=>({...p,mood:m}))} style={{flex:1,padding:"10px 3px",borderRadius:11,border:`2px solid ${logForm.mood===m?C.primary:"#e5e7eb"}`,background:logForm.mood===m?MOODBG[m]:"#fff",cursor:"pointer",fontSize:10,fontWeight:600,color:"#374151"}}>{m}</button>)}
            </div>
          </div>
          <div style={{marginBottom:17}}>
            <div style={{fontSize:12,fontWeight:600,color:"#374151",marginBottom:5}}>Notes (optional)</div>
            <textarea rows={3} placeholder="How did your child respond?" value={logForm.notes} onChange={e=>setLogForm(p=>({...p,notes:e.target.value}))}
              style={{width:"100%",padding:"9px 11px",borderRadius:9,border:"1.5px solid #e5e7eb",fontSize:12,boxSizing:"border-box",resize:"none",outline:"none"}}/>
          </div>
          <button onClick={()=>{if(!logAct||!logForm.mood)return;setLogs(p=>[...p,{...logForm,activityId:logAct.id,activityTitle:logAct.title,date:new Date().toLocaleDateString("en-IN")}]);setLogAct(null);setLogForm({notes:"",mood:""});nav("tracker");}} style={{width:"100%",background:C.accent,color:"#fff",border:"none",borderRadius:12,padding:12,fontSize:14,fontWeight:700,cursor:"pointer"}}>Save Log ✓</button>
        </div>
      </div>
    </div>
  );

  if(screen==="tracker")return(
    <div style={{fontFamily:"sans-serif",background:C.bg,height:"100vh",display:"flex",flexDirection:"column",overflow:"hidden"}}>
