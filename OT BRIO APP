            </div>
          </div>
          <div style={{marginBottom:17}}>
            <div style={{fontSize:12,fontWeight:600,color:"#374151",marginBottom:7}}>Therapy Goals</div>
            <div style={{display:"flex",flexWrap:"wrap",gap:6}}>
              {["Sensory","Fine Motor","Gross Motor","Cognitive","Social"].map(g=>{const sel=pForm.goals.includes(g);return(
                <button key={g} onClick={()=>setPForm(p=>({...p,goals:sel?p.goals.filter(x=>x!==g):[...p.goals,g]}))} style={{padding:"6px 11px",borderRadius:20,border:`2px solid ${sel?C.accent:"#e5e7eb"}`,background:sel?"#d1fae5":"#fff",color:sel?C.accent:"#6b7280",fontWeight:600,cursor:"pointer",fontSize:11}}>{g}</button>
              );})}
            </div>
          </div>
          <button onClick={()=>{if(!pForm.name||!pForm.age||!pForm.condition)return;setProfile(pForm);setScreen("home");}} style={{width:"100%",background:C.primary,color:"#fff",border:"none",borderRadius:12,padding:12,fontSize:14,fontWeight:700,cursor:"pointer"}}>Save Profile ✓</button>
        </div>
      </div>
    </div>
  );

  if(screen==="activities")return(
    <div style={{fontFamily:"sans-serif",background:C.bg,height:"100vh",display:"flex",flexDirection:"column",overflow:"hidden"}}>
