  {id:204,title:"Life Skills DD Teens",         cond:["Developmental Delay"],goal:"Cognitive", age:"11+ yrs",  level:"Medium", mat:"Daily living items",       desc:"Teaching essential life skills for adolescents with developmental delays.", vid:"dc6bX5Oesek"},
  {id:205,title:"Executive Function DD Teen",   cond:["Developmental Delay"],goal:"Cognitive", age:"11+ yrs",  level:"Medium", mat:"Charts, planners",         desc:"Executive function OT tips for focus and organisation in older children.", vid:"SkSsGnSX1lI"},
  {id:206,title:"Fun Teens Special Activities", cond:["Developmental Delay"],goal:"Social",    age:"11+ yrs",  level:"Easy",   mat:"Various",                  desc:"10 fun activities for teenagers with special needs to enjoy.", vid:"hZ1K2TLNoU0"},
  {id:207,title:"Social Peer Play Teens",       cond:["Developmental Delay"],goal:"Social",    age:"11+ yrs",  level:"Medium", mat:"Games, toys",              desc:"Supporting peer play and social interaction for older children.", vid:"IYEGLvvY9zQ"},
  {id:208,title:"Handwriting DD Teen",          cond:["Developmental Delay"],goal:"Fine Motor", age:"11+ yrs", level:"Medium", mat:"Pencil, paper",            desc:"How OT support can improve handwriting skills.", vid:"k3GLtWweens"},
  {id:209,title:"Gross Motor Teen DD",          cond:["Developmental Delay"],goal:"Gross Motor",age:"11+ yrs", level:"Medium", mat:"Open space",               desc:"Gross motor skills activities for older special needs children.", vid:"mQk5svT3bQQ"},
  {id:210,title:"Self-Regulation Teen DD",      cond:["Developmental Delay"],goal:"Cognitive", age:"11+ yrs",  level:"Medium", mat:"None",                     desc:"Self-regulation strategies and techniques for older children.", vid:"fdce30im1qw"},
  {id:211,title:"Sensory Strategies Teen DD",   cond:["Developmental Delay"],goal:"Sensory",   age:"11+ yrs",  level:"Easy",   mat:"Household items",          desc:"Home strategies for sensory processing challenges in teens.", vid:"uZpGsCKFtOI"},
  {id:212,title:"OT Cognitive DD Teen",         cond:["Developmental Delay"],goal:"Cognitive", age:"11+ yrs",  level:"Medium", mat:"Various",                  desc:"Best OT cognitive activities parents can do at home for older children.", vid:"fozW128Cb_U"},
  {id:213,title:"Fine Motor No Tools DD",       cond:["Developmental Delay"],goal:"Fine Motor", age:"11+ yrs", level:"Easy",   mat:"Household items",          desc:"5 fine motor activities at home without fancy therapy tools.", vid:"XxqVXEgtxKw"},
];

const MOODS=["😊 Great","😐 Okay","😢 Struggled"];
const MOODBG={"😊 Great":"#d1fae5","😐 Okay":"#fef9c3","😢 Struggled":"#fee2e2"};
const TIPS=["Keep sessions short — 10–15 minutes is often enough for young children.","Celebrate every small win! Positive reinforcement builds confidence.","Consistency matters — try activities at the same time each day.","Let your child lead sometimes — it boosts engagement.","Take breaks when your child shows frustration or overwhelm.","Use visual schedules to help your child know what to expect.","Sensory breaks before difficult tasks can improve focus.","Pair activities with your child's favourite music or toys."];
const CONCEPTS=[["Sensory Integration","Helping the brain process information from the senses effectively."],["Fine Motor Skills","Small muscle movements — grasping, writing, and buttoning."],["Gross Motor Skills","Larger movements — walking, jumping, and balancing."],["Self-Regulation","A child's ability to manage emotions and behaviour."],["Executive Function","Planning, focus, memory, and managing actions and emotions."],["Proprioception","The sense of body position and movement — helps with coordination."]];
const C={bg:"#f5f3ff",card:"#ffffff",primary:"#7c3aed",light:"#ede9fe",accent:"#059669",warm:"#f59e0b"};

export default function App(){
  const [screen,setScreen]=useState("home");
  const [profile,setProfile]=useState(null);
  const [pForm,setPForm]=useState({name:"",age:"",condition:"",goals:[]});
  const [fCond,setFCond]=useState("All");
  const [fGoal,setFGoal]=useState("All");
  const [fAge,setFAge]=useState("All Ages");
  const [search,setSearch]=useState("");
  const [selAct,setSelAct]=useState(null);
  const [logs,setLogs]=useState([]);
  const [logAct,setLogAct]=useState(null);
  const [logForm,setLogForm]=useState({notes:"",mood:""});
  const today=new Date().toLocaleDateString("en-IN",{day:"numeric",month:"short",year:"numeric"});

  const filtered=useMemo(()=>ACTIVITIES.filter(a=>{
    const cm=fCond==="All"||a.cond.includes(fCond);
    const gm=fGoal==="All"||a.goal===fGoal;
    const am=fAge==="All Ages"||a.age===fAge;
    const sm=!search||a.title.toLowerCase().includes(search.toLowerCase())||a.desc.toLowerCase().includes(search.toLowerCase());
    return cm&&gm&&am&&sm;
  }),[fCond,fGoal,fAge,search]);

  const streak=(()=>{
    const dates=[...new Set(logs.map(l=>l.date))].sort();
    if(!dates.length)return 0;
    let s=1,max=1;
    for(let i=1;i<dates.length;i++){if((new Date(dates[i])-new Date(dates[i-1]))/86400000===1){s++;max=Math.max(max,s);}else s=1;}
    return max;
  })();
  const moodCount=MOODS.reduce((a,m)=>{a[m]=logs.filter(l=>l.mood===m).length;return a},{});
  const nav=s=>{setScreen(s);setSelAct(null);setLogAct(null);};

  const Header=({title})=>(
    <div style={{background:C.primary,color:"#fff",padding:"13px 15px",display:"flex",alignItems:"center",gap:10,borderRadius:"0 0 16px 16px",flexShrink:0}}>
      {screen!=="home"&&<button onClick={()=>nav("home")} style={{background:"rgba(255,255,255,0.2)",border:"none",color:"#fff",borderRadius:8,padding:"4px 10px",cursor:"pointer",fontSize:15}}>←</button>}
      <div style={{flex:1}}>
        <div style={{fontSize:16,fontWeight:700}}>{title}</div>
        {profile&&screen==="home"&&<div style={{fontSize:11,opacity:0.8}}>👤 {profile.name} · {today}</div>}
      </div>
      {screen!=="home"&&<div style={{fontSize:11,opacity:0.75,background:"rgba(255,255,255,0.15)",borderRadius:8,padding:"3px 8px"}}>{ACTIVITIES.length} activities</div>}
    </div>
  );
  const NavBar=()=>(
    <div style={{display:"flex",background:"#fff",borderTop:"1px solid #e5e7eb",flexShrink:0}}>
      {[["🏠","home","Home"],["🧩","activities","Library"],["📋","tracker","Tracker"],["📊","dashboard","Progress"],["💡","tips","Tips"]].map(([icon,s,label])=>(
        <button key={s} onClick={()=>nav(s)} style={{flex:1,padding:"9px 2px",border:"none",background:screen===s?C.light:"transparent",color:screen===s?C.primary:"#6b7280",cursor:"pointer",fontSize:10,display:"flex",flexDirection:"column",alignItems:"center",gap:1,fontWeight:screen===s?700:400}}>
          <span style={{fontSize:17}}>{icon}</span>{label}
        </button>
      ))}
    </div>
  );
  const LBadge=({level})=>{const m={Easy:["#d1fae5","#059669"],Medium:["#fef9c3","#d97706"],Hard:["#fee2e2","#dc2626"]};return <span style={{background:m[level][0],color:m[level][1],borderRadius:7,padding:"2px 7px",fontSize:10,fontWeight:600}}>{level}</span>;};
  const VThumb=({a})=>(
    <a href={`https://www.youtube.com/watch?v=${a.vid}`} target="_blank" rel="noopener noreferrer" style={{display:"block",textDecoration:"none",marginBottom:12}}>
      <div style={{position:"relative",borderRadius:12,overflow:"hidden",background:"#000",cursor:"pointer"}}>
        <img src={`https://img.youtube.com/vi/${a.vid}/hqdefault.jpg`} alt={a.title} style={{width:"100%",height:185,objectFit:"cover",display:"block",opacity:0.85}}/>
        <div style={{position:"absolute",inset:0,display:"flex",alignItems:"center",justifyContent:"center"}}>
          <div style={{background:"rgba(220,0,0,0.92)",borderRadius:"50%",width:52,height:52,display:"flex",alignItems:"center",justifyContent:"center"}}>
            <span style={{color:"#fff",fontSize:20,marginLeft:4}}>▶</span>
          </div>
        </div>
        <div style={{position:"absolute",bottom:7,left:10,color:"#fff",fontSize:11,fontWeight:600,textShadow:"0 1px 4px rgba(0,0,0,0.9)"}}>▶ Watch on YouTube</div>
      </div>
    </a>
  );

  if(screen==="home")return(
    <div style={{fontFamily:"sans-serif",background:C.bg,height:"100vh",display:"flex",flexDirection:"column",overflow:"hidden"}}>
      <Header title="🌟 OT Companion"/>
      <div style={{flex:1,overflowY:"auto",padding:13}}>
        {!profile?(
          <div style={{background:C.card,borderRadius:16,padding:20,textAlign:"center",boxShadow:"0 2px 8px rgba(0,0,0,0.08)"}}>
            <div style={{fontSize:46}}>👶</div>
            <div style={{fontSize:17,fontWeight:700,color:C.primary,marginBottom:8}}>Welcome!</div>
            <div style={{color:"#6b7280",marginBottom:16,fontSize:13}}>Set up your child's profile to get personalised OT activities.</div>
            <button onClick={()=>nav("profile")} style={{background:C.primary,color:"#fff",border:"none",borderRadius:12,padding:"12px 28px",fontSize:14,fontWeight:600,cursor:"pointer"}}>Create Profile</button>
          </div>
        ):(
          <>
            <div style={{background:`linear-gradient(135deg,${C.primary},#a855f7)`,borderRadius:16,padding:16,color:"#fff",marginBottom:13}}>
