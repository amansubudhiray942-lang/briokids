            </div>
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:13}}>
              {[["🎯","Activities",`${ACTIVITIES.length} total`,"activities",C.primary],["📋","Today",""+logs.filter(l=>l.date===today).length+" logged","tracker",C.accent],["📊","Progress",`🔥 ${streak} day streak`,"dashboard",C.warm],["💡","Tips","For parents","tips","#6366f1"]].map(([icon,label,sub,s,c])=>(
                <div key={s} onClick={()=>nav(s)} style={{background:"#fff",borderRadius:13,padding:13,cursor:"pointer",boxShadow:"0 2px 8px rgba(0,0,0,0.07)",borderLeft:`4px solid ${c}`}}>
                  <div style={{fontSize:21}}>{icon}</div>
                  <div style={{fontWeight:700,fontSize:12,color:"#1f2937",marginTop:3}}>{label}</div>
                  <div style={{fontSize:10,color:"#6b7280"}}>{sub}</div>
                </div>
              ))}
            </div>
            <div style={{background:"#fff",borderRadius:13,padding:13,boxShadow:"0 2px 8px rgba(0,0,0,0.06)"}}>
              <div style={{fontWeight:700,color:C.primary,marginBottom:9,fontSize:13}}>🕐 Recent Activities</div>
              {logs.length===0?<div style={{color:"#9ca3af",fontSize:12}}>No activities logged yet. Start today!</div>:
                logs.slice(-4).reverse().map((l,i)=>(
                  <div key={i} style={{display:"flex",justifyContent:"space-between",padding:"6px 0",borderBottom:i<3?"1px solid #f3f4f6":"none"}}>
                    <div><div style={{fontWeight:600,fontSize:12}}>{l.activityTitle}</div><div style={{fontSize:10,color:"#9ca3af"}}>{l.date}</div></div>
                    <div style={{fontSize:19}}>{l.mood.split(" ")[0]}</div>
                  </div>
                ))
              }
            </div>
          </>
        )}
      </div>
      <NavBar/>
    </div>
  );

